# secrets / local config
.env
# deploy secrets (real configs; only the *.example templates are tracked)
/deploy/.env
/deploy/caddy.env

# SigNoz self-host clone (runs separately; not part of our repo)
/signoz/
# Foundry-generated SigNoz deployment (from `foundryctl cast/forge -f casting.yml`) — output, not source
/pours/

# generated collector config (built at container start by merge_config.py)
collector/merged.yaml
# generated fix patches — staged (fixgen output) and active (promoted on apply); .gitkeep tracked
collector/patches/*.yaml
collector/generated/

# python / node noise
__pycache__/
*.pyc
node_modules/
.next/
*.tsbuildinfo
