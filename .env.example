# ─── SigNoz (fill after self-host install — verify, don't assume ports) ───────
SIGNOZ_UI_URL=http://localhost:8080          # whatever you open in the browser
SIGNOZ_API_URL=http://localhost:8080         # confirm base path via devtools
SIGNOZ_API_KEY=                              # SigNoz settings → API keys (admin)
CLICKHOUSE_DSN=clickhouse://default:@clickhouse:9000   # service name inside SigNoz's network
SIGNOZ_DOCKER_NETWORK=signoz-net             # docker network to join (docker network ls)

# ─── LLM (auditor brain + askdocs victim service) ─────────────────────────────
LLM_PROVIDER=anthropic                       # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AUDITOR_MODEL=                               # cheap/fast tier is fine
ASKDOCS_MODEL=                               # the "victim" model

# ─── Pricing assumptions (labeled "assumed rate" in the UI) ───────────────────
PRICE_PER_GB_INGEST=0.30
PRICE_IN_PER_MTOK=3.00
PRICE_OUT_PER_MTOK=15.00

# ─── Audit behavior ───────────────────────────────────────────────────────────
AUDIT_WINDOW_HOURS=24
VERIFY_WINDOW_MINUTES=10

# ─── Waste toggles (OFF by default; `make waste-on` flips all) ────────────────
WASTE_DEBUG_FLOOD=0
WASTE_ORPHAN_METRICS=0
WASTE_HEALTH_SPANS=0
WASTE_CARDINALITY=0
WASTE_LLM_NOCACHE=0
WASTE_LLM_BLOAT=0
ASKDOCS_CACHE=0

# ─── Our services ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://collector:4317        # victims → OUR collector
SIGNOZ_COLLECTOR_OTLP_ENDPOINT=signoz-otel-collector:4317 # OUR collector → SigNoz ingest (host:port, no scheme; CONFIRM service name via docker ps)
AUDITOR_PORT=8100
UI_PORT=3000
