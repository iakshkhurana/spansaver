# Mission Control UI config. Copy to .env.local for local dev.

# The SpanSaver auditor API (FastAPI brain). Matches AUDITOR_PORT in the repo-root .env.
NEXT_PUBLIC_AUDITOR_URL=http://localhost:8100

# Set to "true" to render real-shaped mock fixtures instead of calling the auditor — DESIGN
# PREVIEW ONLY. Must be unset/false for the demo (golden rule #2: no fake numbers on the path).
NEXT_PUBLIC_USE_MOCK=false
