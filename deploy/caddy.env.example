# deploy/caddy.env — Caddy container env (domains + basic-auth). Copy to deploy/caddy.env.
# Loaded literally by compose (env_file), so the bcrypt hash's $ signs are safe here.

APP_DOMAIN=app.example.com
SIGNOZ_DOMAIN=signoz.example.com

# Basic-auth for the guarded auditor endpoints (apply/unapply/verify/explain).
# Generate the hash (keep the $ chars exactly as printed):
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_STRONG_PASSWORD'
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=REPLACE_WITH_CADDY_HASH
