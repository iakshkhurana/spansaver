# deploy/.env — used by docker-compose.prod.yml for ${...} interpolation.
# Copy to deploy/.env and fill in. (Caddy's own vars live in deploy/caddy.env — see below.)

# Public URLs (must match caddy.env domains). Used for auditor CORS + evidence deep-links.
APP_PUBLIC_URL=https://app.example.com
SIGNOZ_PUBLIC_URL=https://signoz.example.com

# The EXTERNAL docker network SigNoz created. Find it with:  docker network ls | grep signoz
# (Foundry-generated; commonly the SigNoz project's default network.)
SIGNOZ_DOCKER_NETWORK=signoz-net
